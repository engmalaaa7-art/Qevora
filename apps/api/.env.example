# Qevora API — Environment Configuration Template
# Do NOT include secrets in this file.

# ─── Environment ───────────────────────────────────────────────────────────────
# e.g., development, production
ENV="development"

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=""

# ─── Upstash Redis ─────────────────────────────────────────────────────────────
# Redis connection details for caching and task queues
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Cloudinary ────────────────────────────────────────────────────────────────
# Cloudinary credentials for media storage
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_URL=""

# ─── AI Provider ───────────────────────────────────────────────────────────────
# API keys for AI integration
ANTHROPIC_API_KEY=""
AI_BASE_URL=""

# ─── Authentication ────────────────────────────────────────────────────────────
# JWT secret for token signing (generate a secure random string)
JWT_SECRET=""
ACCESS_TOKEN_EXPIRE_MINUTES="1440"
REFRESH_TOKEN_EXPIRE_DAYS="7"

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origins for CORS, comma separated
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ─── SMTP (disabled by default) ────────────────────────────────────────────────
# SMTP configuration for email services
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="noreply@qevora.com"
