{
  "name": "qevora-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.16.0",
  "description": "Qevora AI website builder platform monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "turbo run format",
    "generate": "turbo run generate",
    "migrate": "npx prisma migrate dev",
    "seed": "npx tsx infrastructure/database/seed.ts"
  },
  "devDependencies": {
    "prisma": "^5.18.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "tsx": "^4.7.0"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0"
  }
}
